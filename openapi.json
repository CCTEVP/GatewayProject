{
  "openapi": "3.0.3",
  "info": {
    "title": "Gateway Project API",
    "version": "1.0.0",
    "description": "Gateway API for normalizing client query parameters and forwarding requests to an upstream external API."
  },
  "servers": [
    {
      "url": "/",
      "description": "Current server"
    }
  ],
  "tags": [
    {
      "name": "System",
      "description": "Operational endpoints"
    },
    {
      "name": "Gateway",
      "description": "Proxy endpoints for the upstream API"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": ["System"],
        "summary": "Health check",
        "description": "Returns basic service health and whether the upstream API base URL is configured.",
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "Service health status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/weather": {
      "get": {
        "tags": ["Gateway"],
        "summary": "Get weather upstream JSON",
        "description": "Fetches the upstream API and returns the JSON body unchanged. Provide either `latlong` or `playerid`. If `latlong` is present, it is split into `lat` and `lon` before calling the upstream API. If `latlong` is missing and `playerid` is provided, the gateway looks up `playerid` in the local CSV data (`players.csv`) and uses that row's `Latitude`/`Longitude` values. Direct `lat` and `lon` query parameters are not accepted for this endpoint. The gateway reads `EXTERNAL_API_APP_ID` from environment and defaults `units` to `metric` if omitted.",
        "operationId": "getWeatherUpstreamResponse",
        "parameters": [
          {
            "$ref": "#/components/parameters/LatLong"
          },
          {
            "$ref": "#/components/parameters/PlayerId"
          },
          {
            "$ref": "#/components/parameters/BspResourceId"
          },
          {
            "$ref": "#/components/parameters/Units"
          },
          {
            "$ref": "#/components/parameters/Output"
          }
        ],
        "responses": {
          "200": {
            "description": "Weather data in the requested format",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true
                }
              },
              "application/javascript": {
                "schema": {
                  "type": "string",
                  "example": "data = {\"coord\":{\"lon\":12.86,\"lat\":56.67}}"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ErrorJson"
          },
          "404": {
            "$ref": "#/components/responses/ErrorJson"
          },
          "500": {
            "$ref": "#/components/responses/ErrorJson"
          },
          "502": {
            "$ref": "#/components/responses/ErrorJson"
          },
          "504": {
            "$ref": "#/components/responses/ErrorJson"
          }
        }
      }
    },
    "/stats/weather": {
      "get": {
        "tags": ["System"],
        "summary": "Get weather request stats",
        "description": "Returns statistics for successful `/api/weather` requests by combining hashed JSON files from the `stats` directory. Each stats file uses the exact same filename as the matching cache file, and stores separate request groups for incoming query variants that map to that shared normalized request.",
        "operationId": "getWeatherRequestStats",
        "responses": {
          "200": {
            "description": "Weather request statistics",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WeatherRequestStatsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/stats/reset": {
      "post": {
        "tags": ["System"],
        "summary": "Reset stored weather stats",
        "description": "Deletes all generated JSON files from the `stats` directory and returns the number of removed files.",
        "operationId": "resetWeatherRequestStats",
        "responses": {
          "200": {
            "description": "Weather stats reset result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResetResponse"
                }
              }
            }
          }
        }
      }
    },
    "/cache/reset": {
      "post": {
        "tags": ["System"],
        "summary": "Reset cached weather responses",
        "description": "Deletes all generated JSON files from the `cache` directory and returns the number of removed files.",
        "operationId": "resetWeatherCache",
        "responses": {
          "200": {
            "description": "Cache reset result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResetResponse"
                }
              }
            }
          }
        }
      }
    },
    "/openapi.json": {
      "get": {
        "tags": ["System"],
        "summary": "Get the OpenAPI document",
        "description": "Returns the OpenAPI specification used by Swagger UI.",
        "operationId": "getOpenApiDocument",
        "responses": {
          "200": {
            "description": "OpenAPI document",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "LatLong": {
        "name": "latlong",
        "in": "query",
        "required": false,
        "description": "Latitude/longitude pair in `lat,lon` or `lat/lon` format. If provided, the gateway converts it to `lat` and `lon` before forwarding upstream.",
        "schema": {
          "type": "string",
          "example": "3.4545,45.655"
        }
      },
      "PlayerId": {
        "name": "playerid",
        "in": "query",
        "required": false,
        "description": "BroadsignPlayerID looked up in `src/data/players.csv`. If found, its Latitude/Longitude values are used. Alias: com.broadsign.suite.bsp.resource_id.",
        "schema": {
          "type": "string",
          "example": "616575581"
        }
      },
      "BspResourceId": {
        "name": "com.broadsign.suite.bsp.resource_id",
        "in": "query",
        "required": false,
        "description": "Alias for playerid. BroadsignPlayerID looked up in `src/data/players.csv`. If found, its Latitude/Longitude values are used.",
        "schema": {
          "type": "string",
          "example": "616575581"
        }
      },
      "Units": {
        "name": "units",
        "in": "query",
        "required": false,
        "description": "Example passthrough query parameter.",
        "schema": {
          "type": "string",
          "example": "metric"
        }
      },
      "Output": {
        "name": "output",
        "in": "query",
        "required": false,
        "description": "Response format. `js` (default) returns `data = {json}`; `json` returns raw JSON.",
        "schema": {
          "type": "string",
          "enum": ["js", "json"],
          "default": "js"
        }
      }
    },
    "responses": {
      "ErrorJson": {
        "description": "JSON error payload",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    },
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "ok"
          },
          "upstreamConfigured": {
            "type": "boolean",
            "example": true
          }
        },
        "required": ["status", "upstreamConfigured"]
      },
      "ResetResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "ok"
          },
          "scope": {
            "type": "string",
            "enum": ["cache", "stats"]
          },
          "clearedFiles": {
            "type": "integer",
            "example": 3
          }
        },
        "required": ["status", "scope", "clearedFiles"]
      },
      "WeatherRequestGroup": {
        "type": "object",
        "properties": {
          "requestQuery": {
            "type": "object",
            "additionalProperties": true
          },
          "requestQueryString": {
            "type": "string",
            "example": "com.broadsign.suite.bsp.resource_id=616575581"
          },
          "normalizedQuery": {
            "type": "object",
            "additionalProperties": true
          },
          "normalizedQueryString": {
            "type": "string",
            "example": "lat=45.655&lon=3.4545&units=metric"
          },
          "cacheKey": {
            "type": "string"
          },
          "requestCount": {
            "type": "integer",
            "example": 3
          },
          "cacheHits": {
            "type": "integer",
            "example": 2
          },
          "cacheMisses": {
            "type": "integer",
            "example": 1
          },
          "cachedResponses": {
            "type": "integer",
            "example": 2
          },
          "externalApiRequests": {
            "type": "integer",
            "example": 1
          },
          "sourceBreakdown": {
            "type": "object",
            "properties": {
              "cache": {
                "type": "integer",
                "example": 2
              },
              "externalApi": {
                "type": "integer",
                "example": 1
              }
            },
            "required": ["cache", "externalApi"]
          },
          "firstRequestedAt": {
            "type": "string",
            "format": "date-time"
          },
          "lastRequestedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "requestQuery",
          "requestQueryString",
          "normalizedQuery",
          "normalizedQueryString",
          "cacheKey",
          "requestCount",
          "cacheHits",
          "cacheMisses",
          "cachedResponses",
          "externalApiRequests",
          "sourceBreakdown",
          "firstRequestedAt",
          "lastRequestedAt"
        ]
      },
      "WeatherRequestEntry": {
        "type": "object",
        "properties": {
          "requestId": {
            "type": "string"
          },
          "requestedAt": {
            "type": "string",
            "format": "date-time"
          },
          "source": {
            "type": "string",
            "enum": ["cache", "externalApi"]
          },
          "cacheHit": {
            "type": "boolean"
          },
          "requestQuery": {
            "type": "object",
            "additionalProperties": true
          },
          "requestQueryString": {
            "type": "string"
          },
          "normalizedQuery": {
            "type": "object",
            "additionalProperties": true
          },
          "normalizedQueryString": {
            "type": "string"
          },
          "cacheKey": {
            "type": "string"
          },
          "statsFile": {
            "type": "string",
            "description": "The JSON file name in the `stats` directory for this request."
          }
        },
        "required": [
          "requestId",
          "requestedAt",
          "source",
          "cacheHit",
          "requestQuery",
          "requestQueryString",
          "normalizedQuery",
          "normalizedQueryString",
          "cacheKey",
          "statsFile"
        ]
      },
      "WeatherCacheGroupRequest": {
        "type": "object",
        "properties": {
          "requestQuery": {
            "type": "object",
            "additionalProperties": true
          },
          "requestQueryString": {
            "type": "string"
          },
          "requestCount": {
            "type": "integer"
          },
          "cacheHits": {
            "type": "integer"
          },
          "cacheMisses": {
            "type": "integer"
          },
          "cachedResponses": {
            "type": "integer"
          },
          "externalApiRequests": {
            "type": "integer"
          },
          "sourceBreakdown": {
            "type": "object",
            "properties": {
              "cache": {
                "type": "integer"
              },
              "externalApi": {
                "type": "integer"
              }
            },
            "required": ["cache", "externalApi"]
          },
          "firstRequestedAt": {
            "type": "string",
            "format": "date-time"
          },
          "lastRequestedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "requestQuery",
          "requestQueryString",
          "requestCount",
          "cacheHits",
          "cacheMisses",
          "cachedResponses",
          "externalApiRequests",
          "sourceBreakdown",
          "firstRequestedAt",
          "lastRequestedAt"
        ]
      },
      "WeatherCacheGroup": {
        "type": "object",
        "properties": {
          "cacheKey": {
            "type": "string"
          },
          "normalizedQuery": {
            "type": "object",
            "additionalProperties": true
          },
          "normalizedQueryString": {
            "type": "string"
          },
          "requestCount": {
            "type": "integer"
          },
          "cacheHits": {
            "type": "integer"
          },
          "cacheMisses": {
            "type": "integer"
          },
          "cachedResponses": {
            "type": "integer"
          },
          "externalApiRequests": {
            "type": "integer"
          },
          "sourceBreakdown": {
            "type": "object",
            "properties": {
              "cache": {
                "type": "integer"
              },
              "externalApi": {
                "type": "integer"
              }
            },
            "required": ["cache", "externalApi"]
          },
          "firstRequestedAt": {
            "type": "string",
            "format": "date-time"
          },
          "lastRequestedAt": {
            "type": "string",
            "format": "date-time"
          },
          "distinctRequestCount": {
            "type": "integer"
          },
          "requestGroups": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WeatherCacheGroupRequest"
            }
          }
        },
        "required": [
          "cacheKey",
          "normalizedQuery",
          "normalizedQueryString",
          "requestCount",
          "cacheHits",
          "cacheMisses",
          "cachedResponses",
          "externalApiRequests",
          "sourceBreakdown",
          "firstRequestedAt",
          "lastRequestedAt",
          "distinctRequestCount",
          "requestGroups"
        ]
      },
      "WeatherRequestStatsResponse": {
        "type": "object",
        "properties": {
          "totalRequests": {
            "type": "integer",
            "example": 10
          },
          "totalCacheHits": {
            "type": "integer",
            "example": 7
          },
          "totalCacheMisses": {
            "type": "integer",
            "example": 3
          },
          "totalCachedResponses": {
            "type": "integer",
            "example": 7
          },
          "totalExternalApiRequests": {
            "type": "integer",
            "example": 3
          },
          "sourceBreakdown": {
            "type": "object",
            "properties": {
              "cache": {
                "type": "integer",
                "example": 7
              },
              "externalApi": {
                "type": "integer",
                "example": 3
              }
            },
            "required": ["cache", "externalApi"]
          },
          "requestGroups": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WeatherRequestGroup"
            }
          },
          "requests": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WeatherRequestEntry"
            }
          },
          "cacheGroups": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WeatherCacheGroup"
            }
          }
        },
        "required": [
          "totalRequests",
          "totalCacheHits",
          "totalCacheMisses",
          "totalCachedResponses",
          "totalExternalApiRequests",
          "sourceBreakdown",
          "requests",
          "requestGroups",
          "cacheGroups"
        ]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "example": "Query parameter \"latlong\" must be in the form \"lat,lon\"."
          },
          "details": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "required": ["error"]
      }
    }
  }
}
